# Set to your Obsidian vault path so `npm run dev` / `npm run build`
# write main.js + manifest.json + styles.css directly into
# <vault>/.obsidian/plugins/instagram-dm-inbox/ — no manual copy or unzip.
# Leave unset (or delete .env.local) for CI / packaging builds.
OBSIDIAN_VAULT_PATH=/absolute/path/to/your/vault
